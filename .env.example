# ── Application ──
APP_ENV=production
LOG_LEVEL=INFO
LOG_FILE=logs/alibaba-mcp.log

# ── Server ──
PUBLIC_BASE_URL=https://alibaba.prizm-energy.com
HOST=0.0.0.0
PORT=8766

# ── MCP Auth ──
MCP_BEARER_TOKEN=your-secure-bearer-token-here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password-here

# ── Alibaba Open API (openapi.alibaba.com) ──
ALIBABA_APP_KEY=your-alibaba-app-key
ALIBABA_APP_SECRET=your-alibaba-app-secret
ALIBABA_REDIRECT_URI=https://alibaba.prizm-energy.com/auth/callback

# ── Database ──
DATABASE_URL=sqlite:///./data/alibaba_mcp.sqlite3
TOKEN_ENCRYPTION_KEY=

# ── Prizm ERP Integration (optional — for syncing suppliers/quotations) ──
PRIZM_MCP_URL=https://mcp.prizm-energy.com
PRIZM_MCP_TOKEN=

# ── Rate Limits ──
ALIBABA_REQUEST_TIMEOUT_SECONDS=30
ALIBABA_RETRY_ATTEMPTS=3
